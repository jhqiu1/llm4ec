{
  "name": "llm4aad",
  "version": "1.0.0",
  "description": "LLMs for Automated Algorithm Design — Research Community Website",
  "repository": {
    "type": "git",
    "url": "https://github.com/jhqiu1/llm4aad"
  },
  "keywords": [
    "jekyll",
    "theme",
    "academic",
    "evolutionary-computation",
    "large-language-models"
  ],
  "author": "LLM4EC Community",
  "license": "MIT",
  "engines": {
    "node": ">= 0.10.0"
  },
  "dependencies": {
    "fitvids": "^2.1.1",
    "jquery": "^3.7.1",
    "jquery-smooth-scroll": "^2.2.0",
    "magnific-popup": "^1.2.0"
  },
  "devDependencies": {
    "onchange": "^7.1.0",
    "uglify-js": "^3.17.4"
  },
  "scripts": {
    "uglify": "uglifyjs node_modules/jquery/dist/jquery.min.js node_modules/fitvids/dist/fitvids.min.js node_modules/magnific-popup/dist/jquery.magnific-popup.min.js node_modules/jquery-smooth-scroll/jquery.smooth-scroll.min.js assets/js/_main.js -c -m -o assets/js/main.min.js",
    "watch:js": "onchange \"assets/js/**/*.js\" -e \"assets/js/main.min.js\" -- npm run build:js",
    "build:js": "npm run uglify"
  }
}